# ─── Database (Neon Postgres) ───────────────────────────────────────────────
# Use the POOLED connection string for the app at runtime.
# For `prisma migrate` you may use the same string; Neon supports it.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# ─── Auth / JWT ─────────────────────────────────────────────────────────────
# Generate each with:  openssl rand -base64 48
JWT_ACCESS_SECRET="change-me-min-32-chars-long-secret-aaaaaaaa"
JWT_REFRESH_SECRET="change-me-min-32-chars-long-secret-bbbbbbbb"
JWT_SESSION_SECRET="change-me-min-32-chars-long-secret-cccccccc"
ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_TTL_DAYS="30"

# ─── External API (DummyJSON product catalogue) ─────────────────────────────
EXTERNAL_API_BASE_URL="https://dummyjson.com"
EXTERNAL_API_TIMEOUT_MS="4000"

# ─── Upstash Redis (rate limiting) — optional locally ───────────────────────
# Provision via Vercel Marketplace; rate limiting no-ops if these are unset.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ─── Vercel Blob (profile image storage) — optional locally ─────────────────
BLOB_READ_WRITE_TOKEN=""

# ─── Email (Brevo transactional) — optional; logs to console if unset ────────
# Free 300/day, sends to ANY recipient. brevo.com → verify a sender or domain,
# then SMTP & API → API Keys. Without these, verification/reset emails just log
# to the server console (fully testable locally).
BREVO_API_KEY=""
BREVO_SENDER_EMAIL=""
BREVO_SENDER_NAME="Atlas"

# ─── SMS (Twilio Programmable SMS) — optional; logs to console if unset ──────
# Free trial credit + a trial sender number (no Sender-ID registration needed).
# twilio.com/try-twilio → the Console shows your Account SID + Auth Token; claim a
# trial phone number for TWILIO_FROM_NUMBER (E.164, e.g. +15017122661). On a trial
# you can only text numbers you've verified. Without these, OTP codes log to the
# server console (fully testable locally).
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""

# ─── Error monitoring (Sentry) — optional; SDK is inert until a DSN is set ───
# Server DSN + browser DSN (the NEXT_PUBLIC_ one is exposed to the client).
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
# Only needed to upload source maps at build time (set in CI):
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""

# ─── App ────────────────────────────────────────────────────────────────────
APP_URL="http://localhost:3000"
NODE_ENV="development"
