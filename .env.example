# ─── Database (Neon Postgres) ───────────────────────────────────────────────
# Use the POOLED connection string for the app at runtime.
# For `prisma migrate` you may use the same string; Neon supports it.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# ─── Auth / JWT ─────────────────────────────────────────────────────────────
# Generate each with:  openssl rand -base64 48
JWT_ACCESS_SECRET="change-me-min-32-chars-long-secret-aaaaaaaa"
JWT_REFRESH_SECRET="change-me-min-32-chars-long-secret-bbbbbbbb"
ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_TTL_DAYS="30"

# ─── External API (DummyJSON product catalogue) ─────────────────────────────
EXTERNAL_API_BASE_URL="https://dummyjson.com"
EXTERNAL_API_TIMEOUT_MS="4000"

# ─── Upstash Redis (rate limiting) — optional locally ───────────────────────
# Provision via Vercel Marketplace; rate limiting no-ops if these are unset.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ─── Vercel Blob (profile image storage) — optional locally ─────────────────
BLOB_READ_WRITE_TOKEN=""

# ─── App ────────────────────────────────────────────────────────────────────
APP_URL="http://localhost:3000"
NODE_ENV="development"
